  "concepts": {
    "segment": "两点之间线段最短，连接两点线段的长度叫两点间的距离。",
    "midpoint": "线段中点把线段分成相等的两段。",
    "angle_bisector": "角平分线把一个角分成相等的两个角。"
  },
