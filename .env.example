# Copy this file to `.env` and fill in your key.

# Get a free Gemini API key from Google AI Studio: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_api_key_here

# Multiple API keys — rotated round-robin and used for failover on rate limits.
# When a key is throttled (429), Pace automatically tries the next key.
# PACE_API_KEYS=key_1,key_2,key_3

# Model pool — rotated round-robin across agents to spread load / dodge limits.
# Use the EXACT ids your backend accepts (confirm with `python list_models.py`).
# PACE_MODELS=gemini-2.5-flash,gemini-3-flash-preview,gemini-3.1-flash-lite,gemini-2.5-flash-lite

# Or pin a single model (overrides the pool's default first entry):
# PACE_MODEL=gemini-2.5-flash

# --- Using Vertex AI instead of an AI Studio key? Set these instead of GOOGLE_API_KEY ---
# GOOGLE_GENAI_USE_VERTEXAI=TRUE
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
